# =============================================================================
# APP_ENV - REGRA INVIOLAVEL: NAO ALTERAR ESTE VALOR EM PRODUCAO.
# -----------------------------------------------------------------------------
# Em "production", o AppServiceProvider bloqueia migrate:fresh,
# migrate:refresh, migrate:reset, migrate:rollback, db:wipe, db:seed e
# key:generate. Qualquer outro valor reabilita comandos destrutivos.
#
# As protecoes PostgreSQL em database/protection/install_db_protection.sql sao
# uma segunda barreira, nao uma desculpa para enfraquecer esta configuracao.
# =============================================================================
APP_ENV=production
APP_DEBUG=false
APP_URL=https://seu-dominio.com

SESSION_DRIVER=redis
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

CACHE_STORE=redis
QUEUE_CONNECTION=redis

SANCTUM_EXPIRATION=1440
FILAMENT_MFA_REQUIRED=true

SECURITY_API_TOKEN_RATE_LIMIT=5
SECURITY_API_READ_RATE_LIMIT=120
SECURITY_API_WRITE_RATE_LIMIT=30
SECURITY_API_REPORT_RATE_LIMIT=20
SECURITY_PASSWORD_MIN=12
SECURITY_PASSWORD_MIXED_CASE=true
SECURITY_PASSWORD_NUMBERS=true
SECURITY_PASSWORD_SYMBOLS=true
SECURITY_PASSWORD_UNCOMPROMISED=true
SECURITY_HSTS_ENABLED=true
